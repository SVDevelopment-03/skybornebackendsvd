    "seed:coaches": "ts-node --transpile-only src/seeders/coach.seeder.ts",
    "seed:user": "ts-node --transpile-only src/seeders/user.seeder.ts",
    "seed:countries": "ts-node --transpile-only src/seeders/country.seeder.ts",
    "seed:trainerspecific": "ts-node --transpile-only src/seeders/trainer4-attendance.seeder.ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
