  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js & node dist/workers/emailWorker.js & node dist/workers/invoiceEmailWorker.js",
    "start:concurrently": "concurrently --handle-input \"node dist/server.js\" \"node dist/workers/emailWorker.js\" \"node dist/workers/invoiceEmailWorker.js\"",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker:welcome": "node dist/workers/emailWorker.js",
    "worker:invoice": "node dist/workers/invoiceEmailWorker.js",
    "seed:plans": "ts-node --transpile-only src/seeders/plan.seeder.ts",
    "seed:faq": "ts-node --transpile-only src/seeders/faq.seeder.ts",
    "seed:service": "ts-node --transpile-only src/seeders/service.seeder.ts",
